{
  "name": "@easy-reading/website",
  "version": "1.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "clean": "rm -rf .next dist",
    "rebuild": "pnpm clean && pnpm build",
    "static": "next build",
    "fetch-articles": "cross-env NODE_OPTIONS='--loader ts-node/esm' ts-node --project scripts/tsconfig.json scripts/fetch-articles.ts",
    "export-book-resources": "node ./scripts/export-book-resources.mjs",
    "sync-book-covers": "node ./scripts/sync-book-cover-images.mjs",
    "compress-book-covers": "node ./scripts/compress-book-covers.mjs",
    "rename-book-covers": "node ./scripts/rename-book-covers-to-slug.mjs",
    "deploy:preview": "./scripts/deploy.sh preview",
    "deploy:prod": "./scripts/deploy.sh prod",
    "deploy": "./scripts/deploy.sh prod"    
  },
  "dependencies": {
    "@easy-reading/shared": "workspace:*",
    "@types/chrome": "^0.0.309",
    "heroicons": "^2.2.0",
    "next": "^14.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.24",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.16",
    "axios": "^1.8.3",
    "cheerio": "^1.0.0",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
