{
  "name": "easy-reading",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm --filter @easy-reading/shared dev\" \"pnpm --filter @easy-reading/extension dev\" \"pnpm --filter @easy-reading/backend dev\"",
    "dev:extension": "pnpm --filter @easy-reading/chrome-extension dev",
    "dev:website": "pnpm --filter @easy-reading/website dev",
    "build": "pnpm --filter \"@easy-reading/*\" build",
    "clean": "rm -rf node_modules && pnpm --filter './packages/*' clean"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "concurrently": "^8.0.0",
    "esbuild": "^0.18.11",
    "typescript": "^5.0.0"
  }
}